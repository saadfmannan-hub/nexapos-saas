# ---------------------------------------------------------------
# NexaPOS environment configuration (copy to .env and edit)
# ---------------------------------------------------------------

# Platform branding (white-label ready)
PRODUCT_NAME=NexaPOS
PLATFORM_SUPPORT_EMAIL=support@example.com
PLATFORM_WEBSITE=https://example.com
PLATFORM_TERMS_URL=
PLATFORM_PRIVACY_URL=
PLATFORM_PRIMARY_COLOR=#0d6efd

# Core Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL in production; SQLite is used automatically in dev
# when DATABASE_URL is not set)
# DATABASE_URL=postgres://nexapos:nexapos@localhost:5432/nexapos

# Redis / Celery (optional in local development)
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1

# Email (console backend is used in development when unset)
# EMAIL_HOST=
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.com

# Security (production)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Trials
DEFAULT_TRIAL_DAYS=14
